# CryptoTrader v2 — Environment Configuration
# Copy this file to .env and edit as needed.
# The app works out of the box without any changes.

# Ollama server address (default: local)
OLLAMA_HOST=http://localhost:11434

# Model to use for the AI assistant
# Options: mistral (recommended), llama3, phi3, gemma, codellama
OLLAMA_MODEL=mistral
